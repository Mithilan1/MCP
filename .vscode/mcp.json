{
  "inputs": [
    {
      "type": "promptString",
      "id": "context7-key",
      "description": "Context7 API Key",
      "password": true
    }
  ],
  "servers": {
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "${input:context7-key}"
      }
    },
    "notebooklm": {
      "type": "stdio",
      "command": "cmd",
      "args": ["/c", "npx", "notebooklm-mcp@latest"]
    },
    "playwright": {
      "type": "stdio",
      "command": "cmd",
      "args": ["/c", "npx", "@playwright/mcp@latest", "--headless"]
    }
  }
}
